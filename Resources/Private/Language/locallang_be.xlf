            </trans-unit>
            <trans-unit id="backend.analysis.help">
                <source>Each analysis corresponds to a Scheduler task execution with a specific Start Page ID.</source>
            </trans-unit>
            <trans-unit id="backend.refresh">
                <source>Refresh</source>
            </trans-unit>

            <!-- Analysis Configuration -->
            <trans-unit id="backend.analysis.config">
                <source>Selected analysis configuration</source>
            </trans-unit>
