        <header/>
        <body>
            <trans-unit id="plugin.title">
                <source>Semantic Suggestions</source>
            </trans-unit>
            <trans-unit id="plugin.description">
                <source>Suggests semantically related pages</source>
            </trans-unit>
            <trans-unit id="flexforms.parentPageId">
                <source>Parent Page ID</source>
            </trans-unit>
            <trans-unit id="flexforms.proximityThreshold">
                <source>Proximity Threshold</source>
            </trans-unit>

            <!-- Backend Module Translations -->
            <trans-unit id="backend.title">
                <source>Semantic Suggestion - Backend Analysis</source>
            </trans-unit>
            <trans-unit id="backend.title.legacy">
                <source>Semantic Suggestion - Backend Analysis (v12)</source>
            </trans-unit>

            <!-- Error Messages -->
            <trans-unit id="backend.error.no_analysis">
                <source>No analysis available</source>
            </trans-unit>
            <trans-unit id="backend.error.no_analysis.message">
                <source>No similarity analysis found. Please configure and run the "Semantic Suggestion: Generate Similarities" scheduler task.</source>
            </trans-unit>

            <!-- Configuration Instructions -->
            <trans-unit id="backend.config.required">
                <source>Required configuration:</source>
            </trans-unit>
            <trans-unit id="backend.config.step1">
                <source>Go to the <strong>System > Scheduler</strong> module</source>
            </trans-unit>
            <trans-unit id="backend.config.step2">
                <source>Create a new <strong>"Semantic Suggestion: Generate Similarities"</strong> task</source>
            </trans-unit>
            <trans-unit id="backend.config.step3">
                <source>Configure the parameters:</source>
            </trans-unit>
            <trans-unit id="backend.config.param.start_page">
                <source><strong>Start Page ID</strong>: Root page ID for analysis (e.g.: 1)</source>
            </trans-unit>
            <trans-unit id="backend.config.param.threshold">
                <source><strong>Minimum similarity threshold</strong>: Storage threshold (e.g.: 0.3)</source>
            </trans-unit>
            <trans-unit id="backend.config.param.exclude">
                <source><strong>Pages to exclude</strong>: Pages to exclude (optional)</source>
            </trans-unit>
            <trans-unit id="backend.config.step4">
                <source>Schedule execution (daily/weekly during off-peak hours)</source>
            </trans-unit>
            <trans-unit id="backend.config.step5">
                <source>Run the task once for the first time</source>
            </trans-unit>
            <trans-unit id="backend.config.note">
                <source><strong>Note:</strong> The first execution may take time depending on the number of pages to analyze.</source>
            </trans-unit>

            <!-- Analysis Selection -->
            <trans-unit id="backend.analysis.selection">
                <source>Analysis selection</source>
            </trans-unit>
