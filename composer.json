{
    "name": "talan-hdf/semantic-suggestion",
    "version": "4.0.0",
    "type": "typo3-cms-extension",
    "description": "TYPO3 extension for suggesting semantically related pages using advanced NLP and TF-IDF analysis",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Wolfangel Cyril",
            "email": "cyril.wolfangel@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "typo3/cms-core": "^12.4 || ^13.0 || ^14.0",
        "typo3/cms-scheduler": "^12.4 || ^13.0 || ^14.0",
        "cywolf/nlp-tools": "^2.0"
    },

    "autoload": {
        "psr-4": {
            "TalanHdf\\SemanticSuggestion\\": "Classes/",
            "TalanHdf\\SemanticSuggestion\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "semantic_suggestion"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        }
    }
}
